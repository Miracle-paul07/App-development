<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/avatarCreationPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1120">

    <!-- Lottie Background -->
    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/background_anim"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="centerCrop"
        android:alpha="0.6"/>

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"/>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Your Echo"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Design your AI clone"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="32dp"/>

            <!-- Avatar picker row -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose Avatar Style"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Avatar option 1 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@mipmap/ic_launcher"
                            android:background="@drawable/circle_border"
                            android:scaleType="centerCrop"
                            android:padding="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Robot"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Avatar option 2 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@mipmap/ic_launcher_round"
                            android:background="@drawable/circle_border"
                            android:scaleType="centerCrop"
                            android:padding="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cyber"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Avatar option 3 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@mipmap/ic_launcher"
                            android:background="@drawable/circle_border"
                            android:scaleType="centerCrop"
                            android:padding="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ghost"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <!-- Avatar option 4 -->
                    <LinearLayout
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@mipmap/ic_launcher_round"
                            android:background="@drawable/circle_border"
                            android:scaleType="centerCrop"
                            android:padding="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Neon"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#AA1E293B"
                android:padding="24dp"
                android:elevation="10dp">

                <!-- Clone Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clone Name"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/cloneNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What should your clone be called?"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:backgroundTint="#38BDF8"
                    android:layout_marginBottom="24dp"/>

                <!-- Personality -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personality Vibes"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/personalityChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingVertical="8dp"
                    app:chipSpacingHorizontal="8dp"/>

            </LinearLayout>

            <!-- Create Button -->
            <Button
                android:id="@+id/createEchoBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CREATE MY ECHO ✨"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>