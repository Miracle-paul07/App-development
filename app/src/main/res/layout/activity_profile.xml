<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profilePage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1120">

    <!-- Lottie Background -->
    <com.airbnb.lottie.LottieAnimationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/background_anim"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        android:scaleType="centerCrop"
        android:alpha="0.6"/>

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"/>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">
            <!-- Back Button -->
            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent"
                android:tint="#FFFFFF"
                android:layout_gravity="start"
                android:layout_marginBottom="8dp"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Profile"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tell us about yourself"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="36dp"/>

            <!-- Profile Pic Circle -->
            <FrameLayout
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_marginBottom="36dp">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:background="@drawable/circle_border"/>

                <!-- Camera badge -->
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📷"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="#2563EB"
                    android:layout_gravity="bottom|end"
                    android:elevation="4dp"/>

            </FrameLayout>

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#AA1E293B"
                android:padding="28dp"
                android:elevation="10dp">

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your name"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:backgroundTint="#38BDF8"
                    android:layout_marginBottom="20dp"/>

                <!-- Age -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/ageInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your age"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:inputType="number"
                    android:backgroundTint="#38BDF8"
                    android:layout_marginBottom="20dp"/>

                <!-- Bio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/bioInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Something about you..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:backgroundTint="#38BDF8"
                    android:minLines="3"
                    android:gravity="top"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>

            <!-- Button -->
            <Button
                android:id="@+id/createAvatarBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="CONTINUE →"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>